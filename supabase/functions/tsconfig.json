{
  "compilerOptions": {
    "allowJs": true,
    "lib": ["es2020", "dom"],
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "target": "es2020",
    "module": "es2020",
    "types": [],
    "noEmit": true,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "mercadopago-webhook"]
}
